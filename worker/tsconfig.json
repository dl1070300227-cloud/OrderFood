{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "../functions/**/*.ts",
    "../server/src/db/commonDishes.ts",
    "../server/src/db/recipeVideos.ts"
  ]
}
